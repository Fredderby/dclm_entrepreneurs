{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI Backend",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/venv/Scripts/uvicorn.exe",
      "args": ["main:app", "--reload", "--host", "127.0.0.1", "--port", "8080"],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "React Frontend",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "env": { "PORT": "3001" }
    }
  ],
  "compounds": [
    {
      "name": "Start All (Backend + Frontend)",
      "configurations": ["FastAPI Backend", "React Frontend"],
      "stopAll": true
    }
  ]
}